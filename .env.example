APP_ENV=dev
PORT=8080

RENTVINE_PORTAL_URL=https://YOURSUBDOMAIN.rentvine.com/resident
RENTVINE_API_BASE_URL=https://YOURSUBDOMAIN.rentvine.com/api
RENTVINE_API_ACCESS_KEY=replace_me
RENTVINE_API_SECRET=replace_me

RENTVINE_WEBHOOK_SIGNING_KEY=replace_me
RENTVINE_WEBHOOK_SIGNATURE_STRATEGY=hmac_sha256_base64_timestamp_body
RENTVINE_WEBHOOK_SIGNATURE_HEADER=x-rentvine-signature
RENTVINE_WEBHOOK_TIMESTAMP_HEADER=x-rentvine-timestamp
WEBHOOK_VERIFY_ENABLED=true
WEBHOOK_MAX_AGE_SECONDS=300

FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}
DATABASE_URL=postgres://postgres:postgres@postgres:5432/resident_portal
REDIS_URL=redis://redis:6379
